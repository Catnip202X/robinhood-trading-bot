# Copy this file to .env for local development.
# Do not commit .env or any real account credentials.

BOT_MODE=dry-run
BOT_TIMEZONE=America/New_York
BOT_DATABASE_PATH=data/trading-bot.sqlite3
BOT_TECH_WATCHLIST=AAPL,MSFT,NVDA

# Robinhood MCP is expected to be authenticated locally by the user.
# Depending on the MCP client/server you use, these may be unnecessary.
ROBINHOOD_MCP_SERVER_URL=
ROBINHOOD_ACCOUNT_ID=
ROBINHOOD_AUTH_PROFILE=default

# External data providers should be configured locally.
MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=
NEWS_DATA_PROVIDER=
NEWS_DATA_API_KEY=
